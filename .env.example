# Copia este archivo a `.env.local` y rellena con los valores de tu proyecto Supabase.
# Settings → API Keys (la clave "publishable" es segura para el navegador).

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# --- Solo servidor (NUNCA expongas estas en el navegador) ---

# Service-role key de Supabase. La usa el poller/cron para escribir resultados
# saltándose RLS. Settings → API Keys → service_role.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# API-Football (API-SPORTS) — proveedor de resultados en vivo.
# Consíguela gratis en https://dashboard.api-football.com (plan Free ~100 req/día).
# Se envía en la cabecera `x-apisports-key`. SOLO servidor.
APIFOOTBALL_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secreto compartido que protege el endpoint del cron (/api/sync). Genera uno
# aleatorio (p. ej. `openssl rand -hex 32`). Vercel Cron lo envía como
# Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
